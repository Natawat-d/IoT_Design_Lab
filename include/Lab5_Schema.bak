{
  "additionalProperties": false,
  "properties": {
    "humidity": {
      "type": "number"
    },
    "light": {
      "type": "number"
    },
    "temperature": {
      "operation": {
        "transform": {
          "expression": "($.temperature * 1.8) + 32"
        }
      },
      "type": "number"
    }
  }
}