#include <Arduino.h>

// Pin definitions
#define LED1 2              // External LED1 connected to GPIO 2
#define LED_BUILTIN 4       // ESP32 built-in LED (adjust if needed)
#define LDR_PIN 34          // LDR sensor connected to ADC pin (GPIO 34)

// Timer variables
hw_timer_t * timer = NULL;
portMUX_TYPE timerMux = portMUX_INITIALIZER_UNLOCKED;

// State variables
volatile bool toggleLED1 = false;
volatile unsigned long led1Timer = 0;
bool startupComplete = false;
int startupBlinkCount = 0;
unsigned long lastLDRRead = 0;
const unsigned long LDR_READ_INTERVAL = 100; // Read LDR every 100ms

// LED1 blink interval (2 seconds)
const unsigned long LED1_BLINK_INTERVAL = 2000; // 2000ms = 2s

// Timer interrupt service routine
void IRAM_ATTR onTimer() {
  portENTER_CRITICAL_ISR(&timerMux);
  digitalWrite(LED1, !digitalRead(LED1));
  portEXIT_CRITICAL_ISR(&timerMux);
}

__inline__ float adcToLux(int adcValue) ;

void setup() {
  // Initialize serial communication
  Serial.begin(115200);
  
  // Initialize LED pins as output
  pinMode(LED1, OUTPUT);
  pinMode(LED_BUILTIN, OUTPUT);
  
  // Startup blink sequence - both LEDs blink 3 times
  Serial.println("Starting up...");
  for (int i = 0; i < 3; i++) {
    digitalWrite(LED1, HIGH);
    digitalWrite(LED_BUILTIN, HIGH);
    delay(500);
    digitalWrite(LED1, LOW);
    digitalWrite(LED_BUILTIN, LOW);
    delay(500);
  }
  
  startupComplete = true;
  Serial.println("Startup complete.");
  Serial.println("LED1: Status indicator (2s blink)");
  Serial.println("Built-in LED: LDR controlled (threshold: 150)");
  
  // Initialize timer (1 MHz frequency, counts up)
  timer = timerBegin(0, 80, true);
  timerAttachInterrupt(timer, onTimer, true);
  // Set alarm to fire every 2 seconds (2,000,000 microseconds)
  timerAlarmWrite(timer, 2000000, true);
  timerAlarmEnable(timer);
  
  led1Timer = millis();
}

void loop() {
  // LED1 is now controlled by timer interrupt (blinks every 2 seconds)
  if (startupComplete) {
    unsigned long currentMillis = millis();
    
    // Read LDR sensor periodically (non-blocking)
    if (currentMillis - lastLDRRead >= LDR_READ_INTERVAL) {
      float lux_value = adcToLux(analogRead(LDR_PIN));
      
      // Print LDR value to serial monitor
      Serial.print("LDR Value: ");
      Serial.print(lux_value);
      Serial.print(" | LED1: ");
      Serial.print(digitalRead(LED1) ? "ON" : "OFF");
      Serial.print(" | Built-in LED: ");
      
      // Control built-in LED based on LDR value
      if (lux_value > 150) {
        digitalWrite(LED_BUILTIN, HIGH);
        Serial.println("ON");
      } else {
        digitalWrite(LED_BUILTIN, LOW);
        Serial.println("OFF");
      }
      
      lastLDRRead = currentMillis;
    }
  }
  
  // No delay - continuous operation
}

__inline__ float adcToLux(int adcValue) {
  // Adapted Formula: lux = (250 / (ADC_Step * raw_val)) - 50
  // ADC_Step for ESP32 (3.3V / 4095) is approx 0.00080586
  float ADC_value = 0.0008058608f; 
  
  if (adcValue <= 0) return 0.0; // Avoid division by zero or negative
  
  return (250.000000 / (ADC_value * adcValue)) - 50.000000;
}